{
  "name": "dma-platform",
  "version": "0.0.0",
  "description": "Monorepo for the D&D Mapp platform — libraries and applications powering character management, campaign tools, and Virtual Tabletop sessions for D&D 5e.",
  "license": "MIT",
  "private": true,
  "scripts": {
    "ng": "ng",
    "lint:md": "markdownlint-cli2 --config .markdownlint-cli2.json",
    "playwright-install": "playwright install chromium --with-deps",
    "format": "prettier -w .",
    "format-check": "prettier -l ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dnd-mapp/dma-platform.git"
  },
  "engines": {
    "node": "24.16.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.16.0"
    },
    "packageManager": [
      {
        "name": "pnpm",
        "version": "10.34.1",
        "onFail": "error"
      },
      {
        "name": "npm",
        "version": "11.13.0",
        "onFail": "warn"
      }
    ]
  },
  "dependencies": {
    "@angular/animations": "~21.2.14",
    "@angular/cdk": "~21.2.12",
    "@angular/common": "~21.2.14",
    "@angular/compiler": "~21.2.14",
    "@angular/core": "~21.2.14",
    "@angular/forms": "~21.2.14",
    "@angular/platform-browser": "~21.2.14",
    "@angular/router": "~21.2.14",
    "@ngrx/signals": "~21.1.0",
    "rxjs": "~7.8.2",
    "tslib": "~2.8.1"
  },
  "devDependencies": {
    "@angular/build": "~21.2.12",
    "@angular/cli": "~21.2.12",
    "@angular/compiler-cli": "~21.2.14",
    "@playwright/test": "~1.60.0",
    "@types/node": "~24.12.4",
    "@vitest/browser-playwright": "~4.1.7",
    "@vitest/coverage-v8": "~4.1.7",
    "@vitest/ui": "~4.1.7",
    "markdownlint-cli2": "~0.22.1",
    "playwright": "~1.60.0",
    "prettier": "~3.8.3",
    "prettier-plugin-organize-imports": "~4.3.0",
    "typescript": "~5.9.3",
    "vite": "~8.0.14",
    "vitest": "~4.1.7"
  }
}
