{
  "name": "dma-platform",
  "version": "0.0.0",
  "description": "Monorepo for the D&D Mapp platform — libraries and applications powering character management, campaign tools, and Virtual Tabletop sessions for D&D 5e.",
  "license": "MIT",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "certs:generate": "mkcert -cert-file certs/local.pem -key-file certs/local-key.pem localhost.www.dndmapp.dev localhost.auth.dndmapp.dev localhost 127.0.0.1 ::1",
    "moon": "moon",
    "lint-staged": "lint-staged",
    "commitlint": "commitlint",
    "playwright-install": "playwright install chromium --with-deps",
    "lint-md": "markdownlint-cli2 --config .markdownlint-cli2.json",
    "lint-ts": "eslint .",
    "format": "prettier -w .",
    "format-check": "prettier -l ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dnd-mapp/dma-platform.git"
  },
  "engines": {
    "node": "24.18.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.18.0"
    },
    "packageManager": [
      {
        "name": "pnpm",
        "version": "10.34.4",
        "onFail": "error"
      },
      {
        "name": "npm",
        "version": "11.16.0",
        "onFail": "warn"
      }
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@dnd-mapp/eslint-config": "workspace:*",
    "@dnd-mapp/stylelint-config": "workspace:*",
    "@moonrepo/cli": "catalog:",
    "eslint": "catalog:eslint",
    "eslint-config-prettier": "catalog:eslint",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "markdownlint-cli2": "catalog:",
    "playwright": "catalog:playwright",
    "prettier": "catalog:prettier",
    "prettier-plugin-organize-imports": "catalog:prettier",
    "stylelint": "catalog:stylelint",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:eslint"
  }
}
