{
  "name": "dma-platform",
  "version": "0.0.0",
  "description": "Monorepo for the D&D Mapp platform — libraries and applications powering character management, campaign tools, and Virtual Tabletop sessions for D&D 5e.",
  "license": "MIT",
  "private": true,
  "scripts": {
    "lint:md": "markdownlint-cli2 --config .markdownlint-cli2.json",
    "format": "prettier -w .",
    "format-check": "prettier -l ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dnd-mapp/dma-platform.git"
  },
  "engines": {
    "node": "24.16.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.16.0"
    },
    "packageManager": [
      {
        "name": "pnpm",
        "version": "10.34.1",
        "onFail": "error"
      },
      {
        "name": "npm",
        "version": "11.13.0",
        "onFail": "warn"
      }
    ]
  },
  "devDependencies": {
    "markdownlint-cli2": "~0.22.1",
    "prettier": "~3.8.3",
    "prettier-plugin-organize-imports": "~4.3.0"
  }
}
