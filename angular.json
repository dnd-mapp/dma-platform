{
    "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
    "version": 1,
    "newProjectRoot": "apps",
    "cli": {
        "analytics": "f15e5559-8157-4325-8447-47958493338a"
    },
    "schematics": {
        "@schematics/angular:component": {
            "style": "scss",
            "changeDetection": "OnPush"
        }
    },
    "projects": {
        "realm": {
            "projectType": "application",
            "root": "apps/realm",
            "sourceRoot": "apps/realm/src",
            "architect": {
                "build": {
                    "builder": "@angular/build:application",
                    "options": {
                        "assets": [
                            {
                                "glob": "**/*",
                                "input": "apps/realm/public"
                            }
                        ],
                        "browser": "apps/realm/src/main.ts",
                        "index": "apps/realm/src/index.html",
                        "inlineStyleLanguage": "scss",
                        "outputPath": "dist/apps/realm",
                        "styles": ["apps/realm/src/main.scss"],
                        "tsConfig": "apps/realm/tsconfig.app.json"
                    },
                    "defaultConfiguration": "production",
                    "configurations": {
                        "production": {
                            "budgets": [
                                {
                                    "type": "initial",
                                    "maximumWarning": "500kB",
                                    "maximumError": "1MB"
                                },
                                {
                                    "type": "anyComponentStyle",
                                    "maximumWarning": "4kB",
                                    "maximumError": "8kB"
                                }
                            ],
                            "outputHashing": "all",
                            "subresourceIntegrity": true
                        },
                        "development": {
                            "extractLicenses": false,
                            "namedChunks": true,
                            "optimization": false,
                            "sourceMap": true
                        }
                    }
                },
                "serve": {
                    "builder": "@angular/build:dev-server",
                    "options": {
                        "buildTarget": "realm:build:development"
                    }
                },
                "lint": {
                    "builder": "@angular-eslint/builder:lint",
                    "options": {
                        "eslintConfig": "apps/realm/eslint.config.mjs",
                        "lintFilePatterns": ["apps/realm/**/*.ts", "apps/realm/**/*.html"]
                    }
                },
                "test": {
                    "builder": "@angular/build:unit-test",
                    "options": {
                        "buildTarget": "realm:build",
                        "runner": "vitest",
                        "runnerConfig": "apps/realm/vitest.config.mts",
                        "tsConfig": "apps/realm/tsconfig.spec.json"
                    },
                    "defaultConfiguration": "ci",
                    "configurations": {
                        "ci": {
                            "watch": false
                        },
                        "dev": {
                            "ui": true,
                            "watch": true
                        }
                    }
                }
            }
        }
    }
}
