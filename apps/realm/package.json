{
  "name": "@dnd-mapp/realm",
  "version": "0.0.0",
  "description": "Main frontend client for D&D Mapp — character management, campaign tools, and Virtual Tabletop sessions for D&D 5e.",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dnd-mapp/dma-platform.git",
    "directory": "apps/realm"
  },
  "scripts": {
    "start": "ng run realm:serve",
    "build": "ng run realm:build",
    "playwright-install": "playwright install chromium --with-deps",
    "test-ci": "ng run realm:test",
    "test": "ng run realm:test:dev",
    "lint-ts": "ng run realm:lint",
    "lint-css": "stylelint \"**/*.scss\""
  },
  "dependencies": {
    "@angular/animations": "catalog:angular",
    "@angular/cdk": "catalog:angular",
    "@angular/common": "catalog:angular",
    "@angular/compiler": "catalog:angular",
    "@angular/core": "catalog:angular",
    "@angular/forms": "catalog:angular",
    "@angular/platform-browser": "catalog:angular",
    "@angular/platform-browser-dynamic": "catalog:angular",
    "@angular/router": "catalog:angular",
    "@dnd-mapp/arcane-ui": "workspace:*",
    "@dnd-mapp/sigil": "workspace:*",
    "@ngrx/signals": "catalog:ngrx",
    "rxjs": "catalog:",
    "tslib": "catalog:"
  },
  "devDependencies": {
    "@angular-eslint/builder": "catalog:angular",
    "@angular/build": "catalog:angular",
    "@angular/cli": "catalog:angular",
    "@angular/compiler-cli": "catalog:angular",
    "@dnd-mapp/eslint-config": "workspace:*",
    "@dnd-mapp/stylelint-config": "workspace:*",
    "@types/node": "catalog:",
    "@vitest/browser-playwright": "catalog:vitest",
    "@vitest/coverage-v8": "catalog:vitest",
    "@vitest/ui": "catalog:vitest",
    "angular-eslint": "catalog:angular",
    "eslint": "catalog:eslint",
    "eslint-config-prettier": "catalog:eslint",
    "playwright": "catalog:playwright",
    "sass": "catalog:",
    "stylelint": "catalog:stylelint",
    "stylelint-config-clean-order": "catalog:stylelint",
    "stylelint-config-standard-scss": "catalog:stylelint",
    "stylelint-order": "catalog:stylelint",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:eslint",
    "vitest": "catalog:vitest"
  }
}
