{
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "name": "dnd-mapp",
    "projectType": "application",
    "prefix": "dma",
    "sourceRoot": "apps/dnd-mapp/src",
    "tags": ["platform:angular"],
    "targets": {
        "build": {
            "executor": "@angular/build:application",
            "outputs": ["{options.outputPath}"],
            "cache": true,
            "options": {
                "assets": [
                    {
                        "glob": "**/*",
                        "input": "apps/dnd-mapp/public"
                    }
                ],
                "browser": "apps/dnd-mapp/src/main.ts",
                "outputPath": "dist/apps/dnd-mapp",
                "security": {
                    "autoCsp": true
                },
                "styles": ["apps/dnd-mapp/src/styles.css"],
                "tsConfig": "apps/dnd-mapp/tsconfig.app.json"
            },
            "defaultConfiguration": "production",
            "configurations": {
                "production": {
                    "budgets": [
                        {
                            "type": "initial",
                            "maximumWarning": "500kb",
                            "maximumError": "1mb"
                        },
                        {
                            "type": "anyComponentStyle",
                            "maximumWarning": "4kb",
                            "maximumError": "8kb"
                        }
                    ],
                    "subresourceIntegrity": true
                },
                "development": {
                    "namedChunks": true,
                    "optimization": false,
                    "extractLicenses": false,
                    "sourceMap": true,
                    "watch": true
                }
            }
        },
        "serve": {
            "executor": "@angular/build:dev-server",
            "continuous": true,
            "options": {
                "buildTarget": "dnd-mapp:build:development",
                "port": 4200
            },
            "defaultConfiguration": "https",
            "configurations": {
                "https": {
                    "host": "localhost.www.dndmapp.dev",
                    "ssl": true,
                    "sslCert": "cert.pem",
                    "sslKey": "cert-key.pem"
                },
                "http": {}
            }
        },
        "test": {
            "executor": "nx:run-commands",
            "outputs": ["{options.reportsDirectory}"],
            "cache": true,
            "options": {
                "cwd": "{projectRoot}"
            },
            "defaultConfiguration": "ci",
            "configurations": {
                "ci": {
                    "command": "vitest run -c apps/dnd-mapp/vite.config.mts"
                },
                "development": {
                    "command": "vitest -c apps/dnd-mapp/vite.config.mts --ui"
                }
            }
        },
        "lint": {
            "executor": "@nx/eslint:lint"
        }
    }
}
