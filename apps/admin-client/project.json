{
    "$schema": "../../node_modules/nx/schemas/project-schema.json",
    "name": "admin-client",
    "projectType": "application",
    "prefix": "dma",
    "sourceRoot": "apps/admin-client/src",
    "tags": ["platform:angular", "scope:admin-client"],
    "targets": {
        "build": {
            "executor": "@angular/build:application",
            "outputs": ["{options.outputPath}"],
            "cache": true,
            "options": {
                "assets": [
                    {
                        "input": "{projectRoot}/public",
                        "glob": "**/*"
                    },
                    {
                        "input": "libs/shared/ui/public",
                        "glob": "**/*"
                    }
                ],
                "browser": "{projectRoot}/src/main.ts",
                "outputPath": "{workspaceRoot}/dist/{projectRoot}",
                "security": {
                    "autoCsp": true
                },
                "styles": ["{projectRoot}/src/styles.css"],
                "tsConfig": "{projectRoot}/tsconfig.app.json"
            },
            "defaultConfiguration": "production",
            "configurations": {
                "production": {
                    "budgets": [
                        {
                            "type": "initial",
                            "maximumWarning": "500kb",
                            "maximumError": "1mb"
                        },
                        {
                            "type": "anyComponentStyle",
                            "maximumWarning": "4kb",
                            "maximumError": "8kb"
                        }
                    ],
                    "subresourceIntegrity": true
                },
                "development": {
                    "namedChunks": true,
                    "optimization": false,
                    "extractLicenses": false,
                    "sourceMap": true,
                    "watch": true
                }
            }
        },
        "serve": {
            "executor": "@angular/build:dev-server",
            "dependsOn": ["build", "auth-server:serve"],
            "continuous": true,
            "options": {
                "buildTarget": "admin-client:build:development",
                "port": 4400
            },
            "defaultConfiguration": "https",
            "configurations": {
                "https": {
                    "host": "localhost.admin.dndmapp.dev",
                    "ssl": true,
                    "sslCert": "cert.pem",
                    "sslKey": "cert-key.pem"
                },
                "http": {}
            }
        },
        "test": {
            "executor": "nx:run-commands",
            "dependsOn": ["build"],
            "outputs": ["{workspaceRoot}/reports/{projectRoot}"],
            "cache": true,
            "options": {
                "cwd": "{projectRoot}"
            },
            "defaultConfiguration": "ci",
            "configurations": {
                "ci": {
                    "command": "vitest run -c vite.config.mts"
                },
                "development": {
                    "command": "vitest -c vite.config.mts --ui"
                }
            }
        },
        "lint": {
            "executor": "@nx/eslint:lint"
        }
    }
}
