{
    "extends": "../../tsconfig.base.json",
    "references": [{ "path": "tsconfig.lib.json" }, { "path": "tsconfig.spec.json" }],
    "files": [],
    "include": [],
    "compilerOptions": {
        "composite": true,
        "experimentalDecorators": true,
        "incremental": false,
        "lib": ["ES2024", "DOM", "DOM.AsyncIterable", "DOM.Iterable"],
        "module": "es2022",
        "moduleResolution": "bundler",
        "paths": {
            "@dnd-mapp/arcane-ui": ["./src/public-api.ts"],
            "@dnd-mapp/arcane-ui/common": ["./common/public-api.ts"],
            "@dnd-mapp/arcane-ui/components": ["./components/public-api.ts"],
            "@dnd-mapp/arcane-ui/config": ["./config/public-api.ts"],
            "@dnd-mapp/arcane-ui/http": ["./http/public-api.ts"],
            "@dnd-mapp/arcane-ui/icons": ["./icons/public-api.ts"],
            "@dnd-mapp/arcane-ui/icons/testing": ["./icons/testing/public-api.ts"],
            "@dnd-mapp/arcane-ui/storage": ["./storage/public-api.ts"],
            "@dnd-mapp/arcane-ui/storage/testing": ["./storage/testing/public-api.ts"],
            "@dnd-mapp/arcane-ui/testing": ["./testing/public-api.ts"],
            "@dnd-mapp/arcane-ui/theming": ["./theming/public-api.ts"]
        },
        "useDefineForClassFields": false,
        "target": "es2023"
    },
    "angularCompilerOptions": {
        "enableI18nLegacyMessageIdFormat": false,
        "strictInjectionParameters": true,
        "strictStandalone": true,
        "strictTemplates": true
    }
}
