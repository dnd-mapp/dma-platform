{
  "name": "@dnd-mapp/eslint-config",
  "version": "0.0.0",
  "description": "Shared ESLint flat configuration for TypeScript and Angular projects.",
  "keywords": [
    "eslint",
    "eslint-config",
    "typescript",
    "angular",
    "flat-config"
  ],
  "license": "MIT",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.mjs",
    "./angular": "./src/angular.mjs",
    "./node": "./src/node.mjs"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "lint-ts": "eslint ."
  },
  "peerDependencies": {
    "angular-eslint": "^21.0.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "angular-eslint": {
      "optional": true
    }
  },
  "devDependencies": {
    "eslint": "catalog:eslint",
    "eslint-config-prettier": "catalog:eslint",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:eslint"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
